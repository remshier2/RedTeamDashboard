# Red Team Dashboard — viewer build-time configuration.
#
# These are baked into the static bundle at build time (Next.js inlines
# NEXT_PUBLIC_* vars), so the SWA build step / `npm run build` must have them
# set. Copy to `.env.local` for local dev. Get the Entra values from
# `infra/azure-kit/scripts/setup-entra.sh` output.

# The single backend API origin the viewer talks to (replaces the old
# multi-"source" model — one deployment, many engagements inside it).
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Microsoft Entra ID (analyst SSO). Leave blank for local dev to fall back to
# the API-key flow; set all three for real sign-in.
NEXT_PUBLIC_ENTRA_TENANT_ID=
NEXT_PUBLIC_ENTRA_CLIENT_ID=
# The API scope the SPA requests an access token for (api://<client_id>/access_as_user).
NEXT_PUBLIC_ENTRA_API_SCOPE=
